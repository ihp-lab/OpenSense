<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ImportGroup Label="PropertySheets" />
  <PropertyGroup Label="UserMacros" />
  <ItemDefinitionGroup>
    <ClCompile>
      <AdditionalIncludeDirectories>$(SolutionDir)\Shared\lib\hm\default\include;$(SolutionDir)\Shared\lib\hm\default\include\TLibCommon;$(SolutionDir)\Shared\lib\hm\default\include\TLibEncoder;$(SolutionDir)\Shared\lib\hm\default\include\TLibDecoder;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <!--
        RExt__HIGH_BIT_DEPTH_SUPPORT:
        - Defaults to 0 in TypeDef.h, but the HM library was built with HIGH_BITDEPTH=ON.
        - Must be set to 1 here to match, otherwise Pel type mismatch (Short vs Int)
          will cause linker errors.

        _WINDLL:
        - Auto-generated by Visual Studio for DLL projects
      -->
      <PreprocessorDefinitions>RExt__HIGH_BIT_DEPTH_SUPPORT=1;_WINDLL;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
    <Link>
      <AdditionalLibraryDirectories>$(SolutionDir)\Shared\lib\hm\default\lib\$(Platform)\$(Configuration);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>TLibEncoder.lib;TLibDecoder.lib;TLibCommon.lib;Utilities.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>
  <ItemGroup>
    <Content Include="$(ProjectDir)bin\$(Platform)\$(Configuration)\libcrypto-3-x64.dll">
      <Link>%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
</Project>
