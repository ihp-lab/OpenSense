<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <!--NOTE: C++/CLI mixed mode is Windows-only.-->
        <TargetFramework>net8.0-windows</TargetFramework>
        <Platforms>x64</Platforms>
        <PlatformTarget>x64</PlatformTarget>
        <RuntimeIdentifier>win-x64</RuntimeIdentifier>
        <AssemblyName>OpenSense.Components.Kvazaar.Windows</AssemblyName>
        <RootNamespace>OpenSense.Components.Kvazaar</RootNamespace>
        <LangVersion>latest</LangVersion>
        <EmbedAllSources>true</EmbedAllSources>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <Nullable>enable</Nullable>
        <!--
            FIXED_BIT_DEPTH: Kvazaar's some APIs (e.g. encoder->bitdepth, SPS writing) use the
            runtime bitdepth field, but many others (e.g. PIXEL_MAX, interpolation shifts, SATD cost
            scaling, intra DC value) use the compile-time KVZ_BIT_DEPTH constant directly. As a result,
            encoding at a bit depth different from KVZ_BIT_DEPTH produces incorrect output. When this
            symbol is defined, OutputBitDepth and InputBitDepth settings become fixed read-only values
            (= Picture.MaxBitDepth), and the corresponding UI controls are hidden. Remove this symbol
            when Kvazaar fully supports runtime bit depth configuration in the future.
        -->
        <DefineConstants>$(DefineConstants);FIXED_BIT_DEPTH</DefineConstants>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="8.0.2" />
        <PackageReference Include="Microsoft.Psi.Imaging" Version="0.19.100.1-beta" />
        <PackageReference Include="System.Composition" Version="8.0.0" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\ComponentContract\ComponentContract.csproj" />
        <ProjectReference Include="..\..\Interoperations\KvazaarInterop\KvazaarInterop.vcxproj" />
        <ProjectReference Include="..\..\Interoperations\Minimp4Interop\Minimp4Interop.vcxproj" />
    </ItemGroup>

</Project>
