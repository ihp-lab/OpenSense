<UserControl
    x:Class="OpenSense.WPF.Components.HM.HevcEncoderInstanceControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    d:DesignHeight="40"
    d:DesignWidth="300">
    <StackPanel
        Margin="4">
        <ToggleButton
            IsChecked="{Binding ProcessRemainingBeforeStop, Mode=TwoWay}"
            Content="Process Remaining Before Stop"
            ToolTip="When checked, continue encoding remaining queued frames before stopping. When unchecked, stop immediately." />
    </StackPanel>
</UserControl>
