<UserControl
    x:Class="OpenSense.WPF.Components.HM.FileReaderInstanceControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    d:DesignHeight="40"
    d:DesignWidth="300">
    <StackPanel
        Margin="4">
        <ToggleButton
            IsChecked="{Binding AbortOnStop, Mode=TwoWay}"
            Content="Abort On Stop"
            ToolTip="When checked, immediately stop decoding on pipeline stop instead of processing remaining samples." />
    </StackPanel>
</UserControl>
