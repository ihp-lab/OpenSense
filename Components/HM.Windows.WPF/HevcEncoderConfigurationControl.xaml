<UserControl
    x:Class="OpenSense.WPF.Components.HM.HevcEncoderConfigurationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:comp="clr-namespace:OpenSense.Components.HM;assembly=OpenSense.Components.HM.Windows"
    xmlns:interop="clr-namespace:HMInterop;assembly=HMInterop"
    xmlns:util="clr-namespace:OpenSense.WPF.Components.Utilities;assembly=OpenSense.WPF.Components.Contracts"
    xmlns:conv="clr-namespace:OpenSense.WPF.Components.Converters;assembly=OpenSense.WPF.Components.Contracts"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    mc:Ignorable="d"
    d:DesignHeight="800"
    d:DesignWidth="800">
    <d:UserControl.DataContext>
        <comp:HevcEncoderConfiguration />
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <ObjectDataProvider
            x:Key="SliceTypeValues"
            MethodName="GetValues"
            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type
                    TypeName="interop:SliceType" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <conv:BooleanToCollapsedVisibilityConverter
            x:Key="BoolToVis" />
        <conv:InverseBooleanToCollapsedVisibilityConverter
            x:Key="InverseBoolToVis" />
    </UserControl.Resources>

    <!-- Same encoder settings as FileWriterConfigurationControl rows 3-26, with file/muxer rows removed -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition
                Width="auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <!-- 0: Process Remaining Before Stop -->
            <RowDefinition
                Height="auto" />
            <!-- 1: Input Bit Depth -->
            <RowDefinition
                Height="auto" />
            <!-- 2: Input Chroma Format -->
            <RowDefinition
                Height="auto" />
            <!-- 3: Internal Bit Depth -->
            <RowDefinition
                Height="auto" />
            <!-- 4: Lossless -->
            <RowDefinition
                Height="auto" />
            <!-- 5: QP -->
            <RowDefinition
                Height="auto" />
            <!-- 6: Intra Period -->
            <RowDefinition
                Height="auto" />
            <!-- 7: Decoding Refresh Type -->
            <RowDefinition
                Height="auto" />
            <!-- 8: Profile -->
            <RowDefinition
                Height="auto" />
            <!-- 9: Bit Depth Constraint -->
            <RowDefinition
                Height="auto" />
            <!-- 10: Max CU Width -->
            <RowDefinition
                Height="auto" />
            <!-- 11: Max CU Height -->
            <RowDefinition
                Height="auto" />
            <!-- 12: Max Total CU Depth -->
            <RowDefinition
                Height="auto" />
            <!-- 13: Disable Loop Filter -->
            <RowDefinition
                Height="auto" />
            <!-- 14: Use SAO -->
            <RowDefinition
                Height="auto" />
            <!-- 15: Extended Precision -->
            <RowDefinition
                Height="auto" />
            <!-- 16: High Precision Offsets -->
            <RowDefinition
                Height="auto" />
            <!-- 17: Search Range -->
            <RowDefinition
                Height="auto" />
            <!-- 18: Bipred Search Range -->
            <RowDefinition
                Height="auto" />
            <!-- 19: ME Search Method -->
            <RowDefinition
                Height="auto" />
            <!-- 20: Rate Control -->
            <RowDefinition
                Height="auto" />
            <!-- 21: Frame Rate -->
            <RowDefinition
                Height="auto" />
            <!-- 22: Target Bitrate -->
            <RowDefinition
                Height="auto" />
            <!-- 23: Decoded Picture Hash -->
            <RowDefinition
                Height="auto" />
            <!-- 24: GOP Structure -->
            <RowDefinition
                Height="auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Process Remaining Before Stop -->
        <TextBlock
            Grid.Row="0"
            Grid.Column="0">Process Remaining Before Stop</TextBlock>
        <CheckBox
            Grid.Row="0"
            Grid.Column="1"
            IsChecked="{Binding ProcessRemainingBeforeStop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            ToolTip="When enabled, continue encoding remaining queued frames before stopping. When disabled, stop immediately." />

        <!-- Row 1: Input Bit Depth -->
        <TextBlock
            Grid.Row="1"
            Grid.Column="0">Input Bit Depth</TextBlock>
        <ComboBox
            Grid.Row="1"
            Grid.Column="1"
            SelectedValue="{Binding InputBitDepth}"
            SelectedValuePath="Tag"
            ToolTip="Expected input bit depth. Auto = detect at runtime. Set to validate input.">
            <ComboBoxItem
                Content="Auto"
                Tag="{x:Null}" />
            <ComboBoxItem
                Content="8">
                <ComboBoxItem.Tag>
                    <sys:Int32>8</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="9">
                <ComboBoxItem.Tag>
                    <sys:Int32>9</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="10">
                <ComboBoxItem.Tag>
                    <sys:Int32>10</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="11">
                <ComboBoxItem.Tag>
                    <sys:Int32>11</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="12">
                <ComboBoxItem.Tag>
                    <sys:Int32>12</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="13">
                <ComboBoxItem.Tag>
                    <sys:Int32>13</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="14">
                <ComboBoxItem.Tag>
                    <sys:Int32>14</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="15">
                <ComboBoxItem.Tag>
                    <sys:Int32>15</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="16">
                <ComboBoxItem.Tag>
                    <sys:Int32>16</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
        </ComboBox>

        <!-- Row 2: Input Chroma Format -->
        <TextBlock
            Grid.Row="2"
            Grid.Column="0">Input Chroma Format</TextBlock>
        <ComboBox
            Grid.Row="2"
            Grid.Column="1"
            SelectedValue="{Binding InputChromaFormat}"
            SelectedValuePath="Tag"
            ToolTip="Expected input chroma format. Auto = detect at runtime. Set to validate input.">
            <ComboBoxItem
                Content="Auto"
                Tag="{x:Null}" />
            <ComboBoxItem
                Content="Chroma400">
                <ComboBoxItem.Tag>
                    <interop:ChromaFormat>Chroma400</interop:ChromaFormat>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="Chroma420">
                <ComboBoxItem.Tag>
                    <interop:ChromaFormat>Chroma420</interop:ChromaFormat>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="Chroma422">
                <ComboBoxItem.Tag>
                    <interop:ChromaFormat>Chroma422</interop:ChromaFormat>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="Chroma444">
                <ComboBoxItem.Tag>
                    <interop:ChromaFormat>Chroma444</interop:ChromaFormat>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
        </ComboBox>

        <!-- Row 3: Internal Bit Depth -->
        <TextBlock
            Grid.Row="3"
            Grid.Column="0">Internal Bit Depth</TextBlock>
        <ComboBox
            Grid.Row="3"
            Grid.Column="1"
            SelectedValue="{Binding InternalBitDepth}"
            SelectedValuePath="Tag"
            ToolTip="Internal bit depth for encoding. Same as Input = use input bit depth.">
            <ComboBoxItem
                Content="Same as Input"
                Tag="{x:Null}" />
            <ComboBoxItem
                Content="8">
                <ComboBoxItem.Tag>
                    <sys:Int32>8</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="10">
                <ComboBoxItem.Tag>
                    <sys:Int32>10</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="12">
                <ComboBoxItem.Tag>
                    <sys:Int32>12</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="14">
                <ComboBoxItem.Tag>
                    <sys:Int32>14</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="16">
                <ComboBoxItem.Tag>
                    <sys:Int32>16</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
        </ComboBox>

        <!-- Rows 4-24: HM encoder parameters (bound to Raw.XXX) -->
        <!-- These are identical to FileWriterConfigurationControl rows 6-26 -->

        <TextBlock
            Grid.Row="4"
            Grid.Column="0">Lossless</TextBlock>
        <CheckBox
            Grid.Row="4"
            Grid.Column="1"
            IsChecked="{Binding Raw.Lossless, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            ToolTip="Enable lossless encoding mode. Overrides QP setting." />

        <TextBlock
            Grid.Row="5"
            Grid.Column="0"
            Visibility="{Binding Raw.Lossless, Converter={StaticResource InverseBoolToVis}}">QP</TextBlock>
        <TextBox
            Grid.Row="5"
            Grid.Column="1"
            Visibility="{Binding Raw.Lossless, Converter={StaticResource InverseBoolToVis}}"
            Text="{Binding Raw.QP, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            ToolTip="Quantization parameter. Lower values = higher quality." />

        <TextBlock
            Grid.Row="6"
            Grid.Column="0">Intra Period</TextBlock>
        <TextBox
            Grid.Row="6"
            Grid.Column="1"
            Text="{Binding Raw.IntraPeriod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            ToolTip="Intra period (I-frame interval). Use 1 for all-intra encoding." />

        <TextBlock
            Grid.Row="7"
            Grid.Column="0">Decoding Refresh Type</TextBlock>
        <ComboBox
            Grid.Row="7"
            Grid.Column="1"
            ItemsSource="{Binding Source={util:EnumBindingSource {x:Type interop:DecodingRefreshType}}, Mode=OneTime}"
            SelectedItem="{Binding Raw.DecodingRefreshType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="8"
            Grid.Column="0">Profile</TextBlock>
        <ComboBox
            Grid.Row="8"
            Grid.Column="1"
            ItemsSource="{Binding Source={util:EnumBindingSource {x:Type interop:ProfileName}}, Mode=OneTime}"
            SelectedItem="{Binding Raw.Profile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="9"
            Grid.Column="0">Bit Depth Constraint</TextBlock>
        <TextBox
            Grid.Row="9"
            Grid.Column="1"
            Text="{Binding Raw.BitDepthConstraintValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="10"
            Grid.Column="0">Max CU Width</TextBlock>
        <TextBox
            Grid.Row="10"
            Grid.Column="1"
            Text="{Binding Raw.MaxCUWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="11"
            Grid.Column="0">Max CU Height</TextBlock>
        <TextBox
            Grid.Row="11"
            Grid.Column="1"
            Text="{Binding Raw.MaxCUHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="12"
            Grid.Column="0">Max Total CU Depth</TextBlock>
        <TextBox
            Grid.Row="12"
            Grid.Column="1"
            Text="{Binding Raw.MaxTotalCUDepth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="13"
            Grid.Column="0">Disable Loop Filter</TextBlock>
        <CheckBox
            Grid.Row="13"
            Grid.Column="1"
            IsChecked="{Binding Raw.LoopFilterDisable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="14"
            Grid.Column="0">Use SAO</TextBlock>
        <CheckBox
            Grid.Row="14"
            Grid.Column="1"
            IsChecked="{Binding Raw.UseSAO, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="15"
            Grid.Column="0">Extended Precision</TextBlock>
        <CheckBox
            Grid.Row="15"
            Grid.Column="1"
            IsChecked="{Binding Raw.ExtendedPrecision, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="16"
            Grid.Column="0">High Precision Offsets</TextBlock>
        <CheckBox
            Grid.Row="16"
            Grid.Column="1"
            IsChecked="{Binding Raw.HighPrecisionOffsets, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="17"
            Grid.Column="0">Search Range</TextBlock>
        <TextBox
            Grid.Row="17"
            Grid.Column="1"
            Text="{Binding Raw.SearchRange, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="18"
            Grid.Column="0">Bipred Search Range</TextBlock>
        <TextBox
            Grid.Row="18"
            Grid.Column="1"
            Text="{Binding Raw.BipredSearchRange, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="19"
            Grid.Column="0">ME Search Method</TextBlock>
        <ComboBox
            Grid.Row="19"
            Grid.Column="1"
            ItemsSource="{Binding Source={util:EnumBindingSource {x:Type interop:MotionSearchMethod}}, Mode=OneTime}"
            SelectedItem="{Binding Raw.MotionEstimationSearchMethod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="20"
            Grid.Column="0">Rate Control</TextBlock>
        <CheckBox
            Grid.Row="20"
            Grid.Column="1"
            IsChecked="{Binding Raw.UseRateCtrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="21"
            Grid.Column="0"
            Visibility="{Binding Raw.UseRateCtrl, Converter={StaticResource BoolToVis}}">Frame Rate</TextBlock>
        <TextBox
            Grid.Row="21"
            Grid.Column="1"
            Visibility="{Binding Raw.UseRateCtrl, Converter={StaticResource BoolToVis}}"
            Text="{Binding Raw.FrameRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="22"
            Grid.Column="0"
            Visibility="{Binding Raw.UseRateCtrl, Converter={StaticResource BoolToVis}}">Target Bitrate</TextBlock>
        <TextBox
            Grid.Row="22"
            Grid.Column="1"
            Visibility="{Binding Raw.UseRateCtrl, Converter={StaticResource BoolToVis}}"
            Text="{Binding Raw.TargetBitrate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            Grid.Row="23"
            Grid.Column="0">Decoded Picture Hash</TextBlock>
        <ComboBox
            Grid.Row="23"
            Grid.Column="1"
            ItemsSource="{Binding Source={util:EnumBindingSource {x:Type interop:HashType}}, Mode=OneTime}"
            SelectedItem="{Binding Raw.DecodedPictureHashSEIType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <!-- Row 24: GOP Structure -->
        <Expander
            Grid.Row="24"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Header="GOP Structure"
            IsExpanded="False">
            <StackPanel
                Margin="20,5,0,0">
                <Grid
                    Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition
                            Width="auto" />
                        <ColumnDefinition
                            Width="80" />
                        <ColumnDefinition
                            Width="auto" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Margin="0,0,5,0">GOP Size</TextBlock>
                    <TextBox
                        Grid.Column="1"
                        Name="TextBoxGOPSize"
                        Text="{Binding Raw.GOPEntries.Length, Mode=OneTime}" />
                    <Button
                        Grid.Column="2"
                        Margin="5,0,0,0"
                        Click="ButtonApplyGOPSize_Click">Apply</Button>
                </Grid>

                <DataGrid
                    Name="DataGridGOP"
                    ItemsSource="{Binding Raw.GOPEntries}"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    SelectionMode="Single"
                    MinHeight="100"
                    MaxHeight="300"
                    Margin="0,0,0,5">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Header="POC"
                            Binding="{Binding POC, UpdateSourceTrigger=PropertyChanged}"
                            Width="50" />
                        <DataGridComboBoxColumn
                            Header="Type"
                            ItemsSource="{Binding Source={StaticResource SliceTypeValues}}"
                            SelectedItemBinding="{Binding SliceType, UpdateSourceTrigger=PropertyChanged}"
                            Width="60" />
                        <DataGridTextColumn
                            Header="TId"
                            Binding="{Binding TemporalId, UpdateSourceTrigger=PropertyChanged}"
                            Width="40" />
                        <DataGridTextColumn
                            Header="QPOff"
                            Binding="{Binding QPOffset, UpdateSourceTrigger=PropertyChanged}"
                            Width="55" />
                        <DataGridTextColumn
                            Header="QPFact"
                            Binding="{Binding QPFactor, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F4}}"
                            Width="65" />
                        <DataGridCheckBoxColumn
                            Header="RefPic"
                            Binding="{Binding IsReferencePicture, UpdateSourceTrigger=PropertyChanged}"
                            Width="55" />
                        <DataGridTextColumn
                            Header="RefActive"
                            Binding="{Binding NumRefPicsActive, UpdateSourceTrigger=PropertyChanged}"
                            Width="70" />
                    </DataGrid.Columns>
                </DataGrid>

                <GroupBox
                    Header="Additional Parameters for Selected Entry"
                    DataContext="{Binding SelectedItem, ElementName=DataGridGOP}"
                    Margin="0,0,0,5">
                    <Grid
                        Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition
                                Height="auto" />
                            <RowDefinition
                                Height="auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0">Reference Pics</TextBlock>
                        <TextBox
                            Grid.Row="0"
                            Grid.Column="1"
                            Text="{Binding ReferencePicsText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0">Used By Curr Pic</TextBlock>
                        <TextBox
                            Grid.Row="1"
                            Grid.Column="1"
                            Text="{Binding UsedByCurrPicText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                    </Grid>
                </GroupBox>
            </StackPanel>
        </Expander>
    </Grid>
</UserControl>
