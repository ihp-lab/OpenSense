<UserControl
    x:Class="OpenSense.WPF.Components.HM.PictureToDepthImageConverterConfigurationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:OpenSense.WPF.Components.HM"
    xmlns:conv="clr-namespace:OpenSense.WPF.Components.Converters;assembly=OpenSense.WPF.Components.Contracts"
    xmlns:comp="clr-namespace:OpenSense.Components.HM;assembly=OpenSense.Components.HM.Windows"
    xmlns:imaging="clr-namespace:Microsoft.Psi.Imaging;assembly=Microsoft.Psi.Imaging"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    mc:Ignorable="d"
    d:DesignHeight="400"
    d:DesignWidth="800">
    <d:UserControl.DataContext>
        <comp:PictureToDepthImageConverterConfiguration />
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <conv:BooleanToCollapsedVisibilityConverter
            x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition
                Width="auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <!-- 0: Input Bit Depth -->
            <RowDefinition
                Height="auto" />
            <!-- 1: Depth Value Semantics -->
            <RowDefinition
                Height="auto" />
            <!-- 2: Scale Factor -->
            <RowDefinition
                Height="auto" />
            <!-- 3: Bit Depth Mapping Enabled -->
            <RowDefinition
                Height="auto" />
            <!-- 4: Scale Shift -->
            <RowDefinition
                Height="auto" />
            <!-- 5: Input Start -->
            <RowDefinition
                Height="auto" />
            <!-- 6: Output Start -->
            <RowDefinition
                Height="auto" />
            <!-- 7: Mapping Preview -->
            <RowDefinition
                Height="auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Input Bit Depth -->
        <TextBlock
            Grid.Row="0"
            Grid.Column="0">Input Bit Depth</TextBlock>
        <ComboBox
            Grid.Row="0"
            Grid.Column="1"
            SelectedValue="{Binding InputBitDepth}"
            SelectedValuePath="Tag"
            ToolTip="Expected input bit depth. Auto = accept any. Set to validate input at runtime.">
            <ComboBoxItem
                Content="Auto"
                Tag="{x:Null}" />
            <ComboBoxItem
                Content="8">
                <ComboBoxItem.Tag>
                    <sys:Int32>8</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="9">
                <ComboBoxItem.Tag>
                    <sys:Int32>9</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="10">
                <ComboBoxItem.Tag>
                    <sys:Int32>10</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="11">
                <ComboBoxItem.Tag>
                    <sys:Int32>11</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="12">
                <ComboBoxItem.Tag>
                    <sys:Int32>12</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="13">
                <ComboBoxItem.Tag>
                    <sys:Int32>13</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="14">
                <ComboBoxItem.Tag>
                    <sys:Int32>14</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="15">
                <ComboBoxItem.Tag>
                    <sys:Int32>15</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="16">
                <ComboBoxItem.Tag>
                    <sys:Int32>16</sys:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
        </ComboBox>

        <!-- Row 1: Depth Value Semantics -->
        <TextBlock
            Grid.Row="1"
            Grid.Column="0">Depth Value Semantics</TextBlock>
        <ComboBox
            Grid.Row="1"
            Grid.Column="1"
            SelectedValue="{Binding DepthValueSemantics}"
            SelectedValuePath="Tag"
            ToolTip="Depth value semantics to set on the output DepthImage.">
            <ComboBoxItem
                Content="DistanceToPlane">
                <ComboBoxItem.Tag>
                    <imaging:DepthValueSemantics>DistanceToPlane</imaging:DepthValueSemantics>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem
                Content="DistanceToPoint">
                <ComboBoxItem.Tag>
                    <imaging:DepthValueSemantics>DistanceToPoint</imaging:DepthValueSemantics>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
        </ComboBox>

        <!-- Row 2: Scale Factor -->
        <TextBlock
            Grid.Row="2"
            Grid.Column="0">Scale Factor</TextBlock>
        <TextBox
            Grid.Row="2"
            Grid.Column="1"
            Text="{Binding DepthValueToMetersScaleFactor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            ToolTip="Depth-value-to-meters scale factor to set on the output DepthImage. Default 0.001 = millimeters." />

        <!-- Row 3: Bit Depth Mapping Enabled -->
        <TextBlock
            Grid.Row="3"
            Grid.Column="0">Bit Depth Mapping</TextBlock>
        <CheckBox
            Grid.Row="3"
            Grid.Column="1"
            IsChecked="{Binding BitDepthMappingEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            ToolTip="Enable bit depth mapping. Required when source bit depth differs from 16." />

        <!-- Row 4: Scale Shift -->
        <TextBlock
            Grid.Row="4"
            Grid.Column="0"
            Visibility="{Binding BitDepthMappingEnabled, Converter={StaticResource BoolToVis}}">Scale Shift</TextBlock>
        <Grid
            Grid.Row="4"
            Grid.Column="1"
            Visibility="{Binding BitDepthMappingEnabled, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    Width="*" />
                <ColumnDefinition
                    Width="50" />
            </Grid.ColumnDefinitions>
            <Slider
                x:Name="ScaleShiftSlider"
                Grid.Column="0"
                VerticalAlignment="Center"
                IsSnapToTickEnabled="True"
                TickFrequency="1"
                Value="{Binding BitDepthMappingScaleShift, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                ToolTip="Positive = right-shift (downscale), negative = left-shift (upscale), 0 = no scaling." />
            <TextBox
                Grid.Column="1"
                Text="{Binding BitDepthMappingScaleShift, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                VerticalAlignment="Center"
                Margin="4,0,0,0" />
        </Grid>

        <!-- Row 5: Input Start -->
        <TextBlock
            Grid.Row="5"
            Grid.Column="0"
            Visibility="{Binding BitDepthMappingEnabled, Converter={StaticResource BoolToVis}}">Input Start</TextBlock>
        <Grid
            Grid.Row="5"
            Grid.Column="1"
            Visibility="{Binding BitDepthMappingEnabled, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    Width="*" />
                <ColumnDefinition
                    Width="50" />
            </Grid.ColumnDefinitions>
            <Slider
                x:Name="InputStartSlider"
                Grid.Column="0"
                VerticalAlignment="Center"
                IsSnapToTickEnabled="True"
                Value="{Binding BitDepthMappingInputStart, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                ToolTip="Starting position of the mapping window in the source value range." />
            <TextBox
                Grid.Column="1"
                Text="{Binding BitDepthMappingInputStart, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                VerticalAlignment="Center"
                Margin="4,0,0,0" />
        </Grid>

        <!-- Row 6: Output Start -->
        <TextBlock
            Grid.Row="6"
            Grid.Column="0"
            Visibility="{Binding BitDepthMappingEnabled, Converter={StaticResource BoolToVis}}">Output Start</TextBlock>
        <Grid
            Grid.Row="6"
            Grid.Column="1"
            Visibility="{Binding BitDepthMappingEnabled, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    Width="*" />
                <ColumnDefinition
                    Width="50" />
            </Grid.ColumnDefinitions>
            <Slider
                x:Name="OutputStartSlider"
                Grid.Column="0"
                VerticalAlignment="Center"
                IsSnapToTickEnabled="True"
                TickFrequency="1"
                Value="{Binding BitDepthMappingOutputStart, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                ToolTip="Starting position of the mapped values in the target value range." />
            <TextBox
                Grid.Column="1"
                Text="{Binding BitDepthMappingOutputStart, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                VerticalAlignment="Center"
                Margin="4,0,0,0" />
        </Grid>

        <!-- Row 7: Mapping Preview -->
        <local:BitDepthMappingPreview
            Grid.Row="7"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Visibility="{Binding BitDepthMappingEnabled, Converter={StaticResource BoolToVis}}"
            TargetBitDepth="16"
            ScaleShift="{Binding BitDepthMappingScaleShift}"
            InputStart="{Binding BitDepthMappingInputStart}"
            OutputStart="{Binding BitDepthMappingOutputStart}"
            SourceBitDepth="{Binding InputBitDepth, FallbackValue=0, TargetNullValue=0}" />
    </Grid>
</UserControl>
