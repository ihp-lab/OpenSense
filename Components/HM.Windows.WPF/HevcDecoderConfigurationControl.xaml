<UserControl
    x:Class="OpenSense.WPF.Components.HM.HevcDecoderConfigurationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:comp="clr-namespace:OpenSense.Components.HM;assembly=OpenSense.Components.HM.Windows"
    mc:Ignorable="d"
    d:DesignHeight="100"
    d:DesignWidth="800">
    <d:UserControl.DataContext>
        <comp:HevcDecoderConfiguration />
    </d:UserControl.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition
                Width="auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <!-- 0: Process Remaining Before Stop -->
            <RowDefinition
                Height="auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Process Remaining Before Stop -->
        <TextBlock
            Grid.Row="0"
            Grid.Column="0">Process Remaining Before Stop</TextBlock>
        <CheckBox
            Grid.Row="0"
            Grid.Column="1"
            IsChecked="{Binding ProcessRemainingBeforeStop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            ToolTip="When enabled, continue decoding remaining frames before stopping. When disabled, stop immediately." />
    </Grid>
</UserControl>
