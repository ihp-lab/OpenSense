<UserControl
    x:Class="OpenSense.WPF.Components.HM.HevcDecoderInstanceControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    mc:Ignorable="d"
    d:DesignHeight="40"
    d:DesignWidth="300">
    <StackPanel
        Margin="4">
        <ToggleButton
            IsChecked="{Binding DiscardRemainingOnStop, Mode=TwoWay}"
            Content="Discard Remaining On Stop"
            ToolTip="When checked, discard remaining queued frames on stop. When unchecked, decode all remaining frames before closing." />
    </StackPanel>
</UserControl>
